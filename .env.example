NODE_ENV=development
PORT=3000
DATABASE_PATH=database/aionos.db
JWT_SECRET=replace-this-with-a-long-random-secret-before-launch
CORS_ORIGIN=
COOKIE_SECURE=false

# Set these before first production launch to create your real admin account.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=replace-with-12-plus-character-password
ADMIN_USERNAME=aion-admin
ADMIN_DISPLAY_NAME=AION Admin

# Keep false for a clean real forum. Set true only if you want one optional welcome test topic.
SEED_SAMPLE_CONTENT=false
